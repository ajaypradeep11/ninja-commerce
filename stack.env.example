# ─── Stack mode switches ────────────────────────────────────────────────────
# Copy to `stack.env` and edit. `start-stack.sh` reads these to decide how the
# whole stack boots.

# ENV — which environment's config/secrets to use.
#   test → ninja-commerce-test Firebase + test Supabase   (sources stack.secrets.test.env)
#   prod → ninja-commerce-1d830 Firebase + prod Supabase  (sources stack.secrets.prod.env)
# Local checkout always uses the Stripe TEST key regardless of ENV (no live
# charges from a laptop). Default to test — prod points at real user/customer data.
ENV=test

# DATABASE_EMULATOR — which database the LOCAL api talks to.
#   true  → local Docker Postgres (boots `docker compose up -d db`)
#   false → the ENV's Supabase (DATABASE_URL from the sourced secrets file)
DATABASE_EMULATOR=false

# BACKEND_URL — which API the storefront + admin point at.
#   true  → local api at http://localhost:3002 (boots the local api process)
#   false → the ENV's deployed API (DEPLOYED_API_URL; no local api booted, so
#           DATABASE_EMULATOR is ignored)
BACKEND_URL=true

# LAN_EXPOSE — bind the dev servers to all interfaces so other devices on your
# Wi-Fi can reach them.
#   false → loopback only (SAFE DEFAULT).
#   true  → bind 0.0.0.0 + add this machine's LAN IP to the api's CORS allowlist.
LAN_EXPOSE=false
