# ─── TEST environment secrets ────────────────────────────────────────────────
# Copy to `stack.secrets.test.env` and fill REPLACE_ME. Gitignored — never commit
# real values. `start-stack.sh` sources this when ENV=test (the default).

# Firebase web config for the TEST project (these ship publicly in the client
# bundle — not secret, but env-specific).
FIREBASE_API_KEY=REPLACE_ME
FIREBASE_AUTH_DOMAIN=ninja-commerce-test.firebaseapp.com
FIREBASE_PROJECT_ID=ninja-commerce-test
FIREBASE_STORAGE_BUCKET=ninja-commerce-test.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
FIREBASE_APP_ID=REPLACE_ME

# TEST Supabase connection string (session pooler). The genuinely sensitive value.
DATABASE_URL=REPLACE_ME

# Local Docker Postgres (used when DATABASE_EMULATOR=true).
LOCAL_DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce

# Stripe TEST mode. Used by the local API in every env (no live charges locally).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Deployed test/staging API (only needed if BACKEND_URL=false in the test env).
DEPLOYED_API_URL=
