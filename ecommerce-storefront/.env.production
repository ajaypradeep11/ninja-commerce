NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-ecommerce.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-ecommerce
NEXT_PUBLIC_USE_EMULATORS=false
