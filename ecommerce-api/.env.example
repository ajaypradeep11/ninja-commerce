DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce
PORT=3001
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:3000
FIREBASE_PROJECT_ID=
# Set to use the local Firebase Auth emulator (leave unset in production)
FIREBASE_AUTH_EMULATOR_HOST=
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
# Transactional email (order status notifications). Leave SMTP_HOST unset to
# disable sending — emails are logged instead. Fill with your provider's SMTP
# relay (e.g. Resend/SendGrid/Postmark) before real deploys.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="LocalNinja Support <support@localninja.ca>"
