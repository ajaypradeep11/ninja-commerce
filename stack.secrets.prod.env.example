# ─── PRODUCTION environment secrets ──────────────────────────────────────────
# Copy to `stack.secrets.prod.env` and fill REPLACE_ME. Gitignored — never commit
# real values. `start-stack.sh` sources this when ENV=prod.
#
# ⚠️ Running the LOCAL stack with ENV=prod points at REAL Firebase users and the
#    REAL production Supabase data. Even then, local checkout uses the Stripe TEST
#    key below — the live key is deploy-only and never written to a local .env.

# Firebase web config for the PRODUCTION project.
FIREBASE_API_KEY=REPLACE_ME
FIREBASE_AUTH_DOMAIN=ninja-commerce-1d830.firebaseapp.com
FIREBASE_PROJECT_ID=ninja-commerce-1d830
FIREBASE_STORAGE_BUCKET=ninja-commerce-1d830.firebasestorage.app

# PRODUCTION Supabase connection string (session pooler).
DATABASE_URL=REPLACE_ME

# Local Docker Postgres (used when DATABASE_EMULATOR=true).
LOCAL_DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce

# Stripe TEST mode — used by the LOCAL api even in prod env (safety: no live
# charges from a laptop).
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe LIVE secret key — DEPLOY-ONLY. Never written to a local .env; only used
# when deploying the production API (gcloud run deploy --update-env-vars).
STRIPE_SECRET_KEY_LIVE=sk_live_REPLACE_ME

# Deployed production API (used when BACKEND_URL=false).
DEPLOYED_API_URL=https://ninja-commerce-api-1047378822080.us-east4.run.app

# Canada Post AddressComplete key for address autocomplete (optional — form
# degrades to plain typing without it). Client-side, domain-restricted.
NEXT_PUBLIC_ADDRESSCOMPLETE_KEY=
